{{define "content"}}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Scope</h1>
</div>

<div class="row">
  <div class="col-md-5">
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5">Add scope item</h2>
        <form method="POST" action="/admin/scope">
          <input type="hidden" name="gorilla.csrf.Token" value="{{.CSRFToken}}">
          {{if .Data.Error}}<div class="alert alert-danger py-2">{{.Data.Error}}</div>{{end}}
          <div class="mb-3">
            <label class="form-label">CIDR</label>
            <input type="text" name="cidr" required class="form-control" placeholder="10.0.0.0/24">
            <div class="form-text">IPv4 or IPv6 prefix in canonical form.</div>
          </div>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" name="is_blacklist" id="is_blacklist" value="1">
            <label class="form-check-label" for="is_blacklist">Blacklist (exclude from scans)</label>
          </div>
          <button type="submit" class="btn btn-primary">Add</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-7">
    <h2 class="h5">Current scope ({{.Data.Count}})</h2>
    {{if not .Data.Items}}
      <p class="text-muted">No scope items yet.</p>
    {{else}}
      <table class="table table-sm">
        <thead><tr><th>CIDR</th><th>Role</th><th>Created</th><th></th></tr></thead>
        <tbody>
          {{range .Data.Items}}
          <tr>
            <td class="font-monospace">{{.CIDR}}</td>
            <td>
              {{if .IsBlacklist}}<span class="badge bg-danger">blacklist</span>{{else}}<span class="badge bg-success">scope</span>{{end}}
            </td>
            <td class="text-muted small">{{.CreatedAt.Format "2006-01-02 15:04"}}</td>
            <td class="text-end">
              <form method="POST" action="/admin/scope/{{.ID}}/delete" class="d-inline">
                <input type="hidden" name="gorilla.csrf.Token" value="{{$.CSRFToken}}">
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
    {{end}}
  </div>
</div>
{{end}}
